<PhoenixKitWeb.Components.LayoutWrapper.app_layout
  flash={@flash}
  phoenix_kit_current_scope={assigns[:phoenix_kit_current_scope]}
  page_title={@page_title}
  page_subtitle={@page_subtitle}
  current_path={@url_path}
  project_title={@project_title}
>
<div class="container flex-col mx-auto px-4 py-6">
  <%= if @broadcasts == [] do %>
    <.empty_state
      variant="featured"
      icon="hero-megaphone"
      title={gettext("No broadcasts found")}
      description={gettext("Create your first broadcast to get started.")}
    >
      <.pk_link navigate="/admin/newsletters/broadcasts/new" class="btn btn-primary btn-lg">
        <.icon name="hero-plus" class="w-5 h-5 mr-2" /> {gettext("Create first broadcast")}
      </.pk_link>
    </.empty_state>
  <% else %>
    <.table_default
      id="broadcasts-table"
      variant="zebra"
      size="sm"
      class="w-full"
      toggleable
      items={@broadcasts}
      card_fields={
        fn broadcast ->
          [
            %{
              label: gettext("List"),
              value: if(broadcast.list, do: broadcast.list.name, else: "-")
            },
            %{label: gettext("Sent"), value: broadcast.sent_count},
            %{label: gettext("Delivered"), value: broadcast.delivered_count},
            %{label: gettext("Opened"), value: broadcast.opened_count},
            %{label: gettext("Bounced"), value: broadcast.bounced_count},
            %{label: gettext("Sent at"), value: format_datetime(broadcast.sent_at)}
          ]
        end
      }
    >
      <:toolbar_title>
        <label class="select select-sm">
          <select name="status" phx-change="filter_status">
            <option value="" selected={@status_filter == ""}>{gettext("All statuses")}</option>
            <option value="draft" selected={@status_filter == "draft"}>{gettext("Draft")}</option>
            <option value="scheduled" selected={@status_filter == "scheduled"}>
              {gettext("Scheduled")}
            </option>
            <option value="sending" selected={@status_filter == "sending"}>
              {gettext("Sending")}
            </option>
            <option value="sent" selected={@status_filter == "sent"}>{gettext("Sent")}</option>
            <option value="cancelled" selected={@status_filter == "cancelled"}>
              {gettext("Cancelled")}
            </option>
          </select>
        </label>
      </:toolbar_title>
      <:toolbar_actions>
        <.pk_link navigate="/admin/newsletters/broadcasts/new" class="btn btn-primary btn-sm">
          <.icon name="hero-plus" class="w-4 h-4" /> {gettext("New broadcast")}
        </.pk_link>
      </:toolbar_actions>

      <:card_header :let={broadcast}>
        <div class="flex items-start justify-between gap-2">
          <span class="font-medium text-sm truncate">{broadcast.subject}</span>
          <span class={"badge badge-sm #{status_badge_class(broadcast.status)}"}>
            {status_label(broadcast.status)}
          </span>
        </div>
      </:card_header>
      <:card_actions :let={broadcast}>
        <.pk_link
          navigate={"/admin/newsletters/broadcasts/#{broadcast.uuid}"}
          class="btn btn-xs btn-outline"
        >
          {gettext("View")}
        </.pk_link>
      </:card_actions>

      <.table_default_header>
        <.table_default_row>
          <.table_default_header_cell>{gettext("Subject")}</.table_default_header_cell>
          <.table_default_header_cell>{gettext("List")}</.table_default_header_cell>
          <.table_default_header_cell>{gettext("Status")}</.table_default_header_cell>
          <.table_default_header_cell class="text-right">{gettext("Sent")}</.table_default_header_cell>
          <.table_default_header_cell class="text-right">
            {gettext("Delivered")}
          </.table_default_header_cell>
          <.table_default_header_cell class="text-right">{gettext("Opened")}</.table_default_header_cell>
          <.table_default_header_cell class="text-right">{gettext("Bounced")}</.table_default_header_cell>
          <.table_default_header_cell>{gettext("Sent at")}</.table_default_header_cell>
        </.table_default_row>
      </.table_default_header>

      <.table_default_body>
        <.table_default_row
          :for={broadcast <- @broadcasts}
          class="hover cursor-pointer"
          phx-click="view_broadcast"
          phx-value-uuid={broadcast.uuid}
        >
          <.table_default_cell class="font-medium max-w-xs truncate">
            {broadcast.subject}
          </.table_default_cell>
          <.table_default_cell>
            <%= if broadcast.list do %>
              {broadcast.list.name}
            <% else %>
              <span class="text-base-content/40">-</span>
            <% end %>
          </.table_default_cell>
          <.table_default_cell>
            <span class={"badge badge-sm #{status_badge_class(broadcast.status)}"}>
              {status_label(broadcast.status)}
            </span>
          </.table_default_cell>
          <.table_default_cell class="text-right">{broadcast.sent_count}</.table_default_cell>
          <.table_default_cell class="text-right">
            {broadcast.delivered_count}
          </.table_default_cell>
          <.table_default_cell class="text-right">
            {broadcast.opened_count}
          </.table_default_cell>
          <.table_default_cell class="text-right">
            {broadcast.bounced_count}
          </.table_default_cell>
          <.table_default_cell class="text-sm text-base-content/70">
            {format_datetime(broadcast.sent_at)}
          </.table_default_cell>
        </.table_default_row>
      </.table_default_body>
    </.table_default>
  <% end %>
</div>
</PhoenixKitWeb.Components.LayoutWrapper.app_layout>
